# Arkoo Prebuild Lead Automation Environment Variables
# Copy this file to .env and fill in your actual credentials

# SMTP Configuration (For sending emails via SendGrid, Mailgun, or Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Email Addresses
SALES_EMAIL=sales@arkooprebuild.com
SYSTEM_EMAIL=arkooprebuildai@gmail.com

# Public base URL of the Arkoo LMS app (used to generate /apply links in customer emails)
# Example for local dev: http://localhost:5173
# Example for production: https://your-lms-domain.com
APP_BASE_URL=http://localhost:5173
