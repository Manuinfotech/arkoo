# --- ARKOO API SERVER ENVIRONMENT VARIABLES ---
PORT=3002
# APP_BASE_URL="https://arkoo-infra.onrender.com" # Define your live web URL here to override dynamic host detection if needed

# --- GOOGLE SHEETS INTEGRATION ---
# 1. Create a Project in Google Cloud Console
# 2. Enable "Google Sheets API"
# 3. Create a Service Account and download the JSON key
# 4. Paste the client_email below
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@your-project-id.iam.gserviceaccount.com"

# 5. Paste the private_key below exactly as it is in the JSON file (including the \n characters)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_LONG_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# 6. Open your target Google Sheet and copy the long ID from the URL:
# (e.g., https://docs.google.com/spreadsheets/d/THIS_IS_THE_SHEET_ID/edit)
# IMPORTANT: Share this Google Sheet as "Editor" with the GOOGLE_SERVICE_ACCOUNT_EMAIL above!
GOOGLE_SHEET_ID="1TphG3jI0yCdI7Ey6sbwhlfu1K51lPkWNQYSNKby__fY"

