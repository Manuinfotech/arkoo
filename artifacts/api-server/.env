# --- META / INSTAGRAM WEBHOOK CONFIGURATION ---
# 1. Go to https://developers.facebook.com/apps/ → Create App (Business type)
# 2. Add Product: Webhooks → Page → Subscribe to "leadgen" field
# 3. Set Callback URL: https://arkoo-infra.onrender.com/api/webhooks/meta
# 4. Set Verify Token to the value below and click "Verify and Save"
META_VERIFY_TOKEN="arkoo_meta_verify_2026"
# 5. After verification, go to your Page Access Token and paste it below
META_PAGE_ACCESS_TOKEN=""
# 6. Your Meta App ID (from the app dashboard)
META_APP_ID=""
# 7. Your Meta App Secret (from the app dashboard — used for payload signature)
META_APP_SECRET=""

# --- LINKEDIN WEBHOOK CONFIGURATION ---
# 1. Go to https://developers.linkedin.com/apps → Create App
# 2. Under Products → Request "Lead Gen Forms API" access (1-5 business days approval)
# 3. After approval, add OAuth scopes: rw_leads, r_ads_leadgen_automation
# 4. Paste your Client ID and Client Secret below
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
# 5. Call GET /api/webhooks/linkedin/auth-url → open the returned URL → authorize
# 6. After redirect, the access token will be displayed — paste it here
LINKEDIN_ACCESS_TOKEN=""
# 7. This secret is used to verify LinkedIn's HMAC-SHA256 webhook signatures
# Set this same value in the LinkedIn Developer Console → Webhooks → Webhook Secret
LINKEDIN_WEBHOOK_SECRET="arkoo_linkedin_secret_2026"
# 8. Register your webhook in LinkedIn Console:
#    URL: https://arkoo-infra.onrender.com/api/webhooks/linkedin
#    Event: Lead Gen Form Response
LINKEDIN_REDIRECT_URI="https://arkoo-infra.onrender.com/api/webhooks/linkedin/callback"

